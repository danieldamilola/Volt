<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/CommonStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════════════════
         DARK THEME — Volt Design System
         All rgba() values converted to WPF #AARRGGBB
         ═══════════════════════════════════════════════════════════ -->

    <!-- Glass background: rgba(20,20,22,0.78) → alpha=199=#C7 -->
    <SolidColorBrush x:Key="GlassBg"         Color="#C7141416"/>
    <!-- Glass border: rgba(255,255,255,0.08) → alpha=20=#14 -->
    <SolidColorBrush x:Key="GlassBorder"     Color="#14FFFFFF"/>
    <!-- Preview panel bg: rgba(18,18,20,0.85) → alpha=217=#D9 -->
    <SolidColorBrush x:Key="PreviewBg"       Color="#D9121214"/>

    <!-- Surfaces - will be updated dynamically -->
    <SolidColorBrush x:Key="Surface"         Color="#141416"/>
    <SolidColorBrush x:Key="SurfaceLow"      Color="#242426"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextSecondary"   Color="#8A8A8A"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#555555"/>

    <!-- Borders -->
    <!-- rgba(255,255,255,0.06) → alpha=15=#0F -->
    <SolidColorBrush x:Key="BorderBrush"     Color="#0FFFFFFF"/>
    <!-- rgba(255,255,255,0.10) → alpha=26=#1A -->
    <SolidColorBrush x:Key="BorderStrong"    Color="#1AFFFFFF"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectedBg"      Color="#1c1c1d"/>
    <SolidColorBrush x:Key="SelectedText"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SelectedMuted"   Color="#AAAAAA"/>
    <SolidColorBrush x:Key="HoverBg"         Color="#1AFFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent"          Color="#5B7EFF"/>
    <SolidColorBrush x:Key="AccentWash"      Color="#171F42"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="Green"           Color="#5EE577"/>
    <SolidColorBrush x:Key="Orange"          Color="#FFC779"/>
    <SolidColorBrush x:Key="Red"             Color="#FF7B7B"/>

    <!-- ToggleSwitch -->
    <SolidColorBrush x:Key="ToggleKnob"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToggleTrackOff"  Color="#555555"/>

    <!-- TextBox selection opacity (theme-specific) -->
    <sys:Double x:Key="TextSelectionOpacity">0.35</sys:Double>

    <!-- ═══ Typography ═══════════════════════════════════════════ -->
    <FontFamily x:Key="UIFont">pack://application:,,,/Themes/Fonts/#DM Sans</FontFamily>
    <FontFamily x:Key="MonoFont">pack://application:,,,/Themes/Fonts/#DM Mono</FontFamily>

    <!-- Font sizes -->
    <sys:Double x:Key="FontXxs">10</sys:Double>
    <sys:Double x:Key="FontXs">11</sys:Double>
    <sys:Double x:Key="FontSm">12</sys:Double>
    <sys:Double x:Key="FontMono13">13</sys:Double>
    <sys:Double x:Key="FontBase">14</sys:Double>
    <sys:Double x:Key="FontMd">15</sys:Double>
    <sys:Double x:Key="FontIp">16</sys:Double>
    <sys:Double x:Key="FontLg">17</sys:Double>
    <sys:Double x:Key="FontXl">20</sys:Double>
    <sys:Double x:Key="FontXxl">32</sys:Double>
    <sys:Double x:Key="FontDisplay">48</sys:Double>

    <!-- ═══ Geometry ══════════════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusPill">28</CornerRadius>
    <CornerRadius x:Key="RadiusWindow">16</CornerRadius>
    <CornerRadius x:Key="RadiusRow">8</CornerRadius>
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusButton">6</CornerRadius>
    <CornerRadius x:Key="RadiusCircle">18</CornerRadius>

    <sys:Double x:Key="SearchBarHeight">56</sys:Double>
    <sys:Double x:Key="RowHeight">52</sys:Double>
    <sys:Double x:Key="CategoryButtonSize">36</sys:Double>
    <sys:Double x:Key="WindowWidth">680</sys:Double>

    <!-- ═══ Shadow ════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="WindowShadow"
                      BlurRadius="64"
                      ShadowDepth="16"
                      Direction="270"
                      Opacity="0.5"
                      Color="#000000"/>


</ResourceDictionary>
