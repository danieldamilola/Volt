<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/CommonStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════════════════
         LIGHT THEME — Volt Design System
         ═══════════════════════════════════════════════════════════ -->

    <!-- Glass background: rgba(255,255,255,0.72) → alpha=184=#B8 -->
    <SolidColorBrush x:Key="GlassBg"         Color="#B8FFFFFF"/>
    <!-- Glass border: rgba(255,255,255,0.5) → alpha=128=#80 -->
    <SolidColorBrush x:Key="GlassBorder"     Color="#80FFFFFF"/>
    <!-- Preview panel bg: rgba(255,255,255,0.85) → alpha=217=#D9 -->
    <SolidColorBrush x:Key="PreviewBg"       Color="#D9FFFFFF"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Surface"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceLow"      Color="#F5F5F5"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#0A0A0A"/>
    <SolidColorBrush x:Key="TextSecondary"   Color="#6B6B6B"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#A0A0A0"/>

    <!-- Borders -->
    <!-- rgba(0,0,0,0.08) → alpha=20=#14 -->
    <SolidColorBrush x:Key="BorderBrush"     Color="#14000000"/>
    <!-- rgba(0,0,0,0.14) → alpha=36=#24 -->
    <SolidColorBrush x:Key="BorderStrong"    Color="#24000000"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectedBg"      Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SelectedText"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SelectedMuted"   Color="#AAAAAA"/>
    <SolidColorBrush x:Key="HoverBg"         Color="#0F000000"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent"          Color="#3650D4"/>
    <SolidColorBrush x:Key="AccentWash"      Color="#E8EDFB"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="Green"           Color="#1A7A40"/>
    <SolidColorBrush x:Key="Orange"          Color="#A04F00"/>
    <SolidColorBrush x:Key="Red"             Color="#C0180F"/>

    <!-- ToggleSwitch -->
    <SolidColorBrush x:Key="ToggleKnob"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToggleTrackOff"  Color="#A0A0A0"/>

    <!-- TextBox selection opacity (theme-specific) -->
    <sys:Double x:Key="TextSelectionOpacity">0.25</sys:Double>

    <!-- ═══ Typography (same as dark) ════════════════════════════ -->
    <FontFamily x:Key="UIFont">pack://application:,,,/Themes/Fonts/#DM Sans</FontFamily>
    <FontFamily x:Key="MonoFont">pack://application:,,,/Themes/Fonts/#DM Mono</FontFamily>

    <sys:Double x:Key="FontXxs">10</sys:Double>
    <sys:Double x:Key="FontXs">11</sys:Double>
    <sys:Double x:Key="FontSm">12</sys:Double>
    <sys:Double x:Key="FontMono13">13</sys:Double>
    <sys:Double x:Key="FontBase">14</sys:Double>
    <sys:Double x:Key="FontMd">15</sys:Double>
    <sys:Double x:Key="FontIp">16</sys:Double>
    <sys:Double x:Key="FontLg">17</sys:Double>
    <sys:Double x:Key="FontXl">20</sys:Double>
    <sys:Double x:Key="FontXxl">32</sys:Double>
    <sys:Double x:Key="FontDisplay">48</sys:Double>

    <!-- ═══ Geometry (same as dark) ══════════════════════════════ -->
    <CornerRadius x:Key="RadiusPill">28</CornerRadius>
    <CornerRadius x:Key="RadiusWindow">16</CornerRadius>
    <CornerRadius x:Key="RadiusRow">8</CornerRadius>
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusButton">6</CornerRadius>
    <CornerRadius x:Key="RadiusCircle">18</CornerRadius>

    <sys:Double x:Key="SearchBarHeight">56</sys:Double>
    <sys:Double x:Key="RowHeight">52</sys:Double>
    <sys:Double x:Key="CategoryButtonSize">36</sys:Double>
    <sys:Double x:Key="WindowWidth">680</sys:Double>

    <!-- ═══ Shadow (lighter for light mode) ══════════════════════ -->
    <DropShadowEffect x:Key="WindowShadow"
                      BlurRadius="48"
                      ShadowDepth="12"
                      Direction="270"
                      Opacity="0.25"
                      Color="#000000"/>


</ResourceDictionary>
