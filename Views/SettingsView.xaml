<UserControl x:Class="Arc.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Arc.Views"
             xmlns:conv="clr-namespace:Arc.Converters">

    <UserControl.Resources>

        <!-- Section visibility converter -->
        <local:SectionVisibilityConverter x:Key="SectionVisibility"/>

        <!-- ── Setting card — clean white/glass surface ───────────────── -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Depth2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── Card row — each setting row inside a card ──────────────── -->
        <Style x:Key="CardRow" TargetType="Border">
            <Setter Property="Padding" Value="16,18"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── Row divider ────────────────────────────────────────────── -->
        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Margin" Value="16,0,0,0"/>
        </Style>

        <!-- ── Section group label ────────────────────────────────────── -->
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin" Value="4,18,0,6"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <!-- ── Setting title text ─────────────────────────────────────── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <!-- ── Setting description / hint text ───────────────────────── -->
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>

        <!-- ── Icon container (32×32) ────────────────────────────────── -->
        <Style x:Key="IconContainer" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource Depth3}"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- ── Segmented pill container ──────────────────────────────── -->
        <Style x:Key="Seg" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Depth3}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <!-- ── Icon-only button (28×28) ──────────────────────────────── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Sidebar nav button ─────────────────────────────────────── -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                                       FontFamily="{DynamicResource UIFont}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource HoverBg}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost action button (Edit shortcut, Refresh, Clear, etc.) ─ -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Background" Value="{DynamicResource Depth3}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Depth4}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger button (destructive action) ────────────────────── -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Foreground" Value="{DynamicResource Red}"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="16,0">
            <TextBlock Text="Settings"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <Button Click="OnCloseClick"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="28" Height="28"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" FocusVisualStyle="{x:Null}"
                    ToolTip="Close (Esc)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                            <Path Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Path.Data>
                                    <Binding Source="x" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                </Path.Data>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <!-- ══ SIDEBAR + CONTENT ════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="148"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ─────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          Padding="10,12,8,12">
                <ItemsControl x:Name="SidebarList" ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SidebarBtn}"
                                    Content="{Binding Name}"
                                    Click="OnSectionClick"
                                    Margin="0,0,0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Sidebar divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- ── Content ─────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,16,20,24">

                <!-- ════════════════════ General ════════════════════════ -->
                <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibility}, ConverterParameter=General}">

                    <!-- Group: Appearance -->
                    <TextBlock Text="APPEARANCE" Style="{StaticResource GroupLabel}" Margin="4,4,0,6"/>

                    <!-- Appearance card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <!-- Theme row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="palette" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Theme" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Light, dark, or match your system" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource Seg}" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="Dark"   IsChecked="{Binding ThemeDark}"   Style="{StaticResource SegmentedRadio}" GroupName="Theme"/>
                                            <RadioButton Content="Light"  IsChecked="{Binding ThemeLight}"  Style="{StaticResource SegmentedRadio}" GroupName="Theme"/>
                                            <RadioButton Content="System" IsChecked="{Binding ThemeSystem}" Style="{StaticResource SegmentedRadio}" GroupName="Theme"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Accent color row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentCalculator}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="paintbrush" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Accent color" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Follow Windows or use a custom hex" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource Seg}">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton Content="Windows" IsChecked="{Binding UseWindowsAccentColor}" Style="{StaticResource SegmentedRadio}" GroupName="Accent"/>
                                                <RadioButton Content="Custom"  IsChecked="{Binding UseCustomAccentColor}"  Style="{StaticResource SegmentedRadio}" GroupName="Accent"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Depth3}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="7" Height="26" Width="68" Margin="8,0,0,0" Padding="8,0">
                                            <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=LostFocus}"
                                                     VerticalContentAlignment="Center"
                                                     FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                                     Foreground="{DynamicResource TextPrimary}" Background="Transparent" BorderThickness="0">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UseWindowsAccentColor}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Opacity" Value="0.35"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Glass effect row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentClipboard}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Glass effect" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Blur and transparency behind the launcher" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding EnableBlur, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Group: Window -->
                    <TextBlock Text="WINDOW" Style="{StaticResource GroupLabel}"/>

                    <!-- Window card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <!-- Width row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentFiles}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="maximize" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Width" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="{Binding LauncherWidth, StringFormat='{}{0:0}px'}"
                                                   FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Slider Grid.Column="2" Value="{Binding LauncherWidth, Mode=TwoWay, Delay=500}"
                                            Minimum="500" Maximum="900" Width="120"
                                            SmallChange="10" LargeChange="50" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Search Window Location row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="monitor" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Search Window Location" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding SearchWindowLocations}"
                                              SelectedItem="{Binding SearchWindowLocation, Mode=TwoWay}"
                                              Width="160" Height="28" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Search Window Position row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="monitor" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Search Window Position on Monitor" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding SearchWindowPositions}"
                                              SelectedItem="{Binding SearchWindowPosition, Mode=TwoWay}"
                                              Width="160" Height="28" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Ignore Hotkeys row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="gamepad-2" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Ignore hotkeys in fullscreen mode" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Disable Arc activation when a full screen application is active (Recommended for games)." Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding IgnoreHotkeysInFullscreen, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Always Preview row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="panel-right" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Always Preview" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Always open preview panel when Arc activates. Press F1 to toggle preview." Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding AlwaysPreview, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Opacity row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="blend" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Opacity" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Background transparency level" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <Slider Grid.Column="2" Width="100" Minimum="0.5" Maximum="1.0"
                                            Value="{Binding WindowOpacity, Mode=TwoWay}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Compact mode row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentTime}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="layout-grid" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Compact mode" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Hide results when query is empty" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding CompactMode, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- Placeholder text row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="type" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Placeholder text" Style="{StaticResource SectionTitle}"/>
                                        <TextBox Text="{Binding PlaceholderText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Height="26" Padding="8,4" Margin="0,4,0,0" Width="180" HorizontalAlignment="Left"
                                                 FontFamily="{DynamicResource UIFont}" FontSize="12"
                                                 Background="{DynamicResource Depth3}" BorderBrush="{DynamicResource BorderBrush}"
                                                 BorderThickness="1" Foreground="{DynamicResource TextPrimary}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding ShowPlaceholder, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Group: System -->
                    <TextBlock Text="SYSTEM" Style="{StaticResource GroupLabel}"/>

                    <!-- Effects card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentClipboard}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="zap" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Animation" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Smooth open and close transitions" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding AnimationEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentTime}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="volume-2" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Sound effects" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Play sounds on actions" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding SoundEffectEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Green}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="power" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Launch on startup" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Start Arc when Windows boots" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding LaunchOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="monitor-dot" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Tray icon" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Show Arc in the system tray" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding ShowTrayIcon, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Group: Hotkey -->
                    <TextBlock Text="KEYBOARD" Style="{StaticResource GroupLabel}"/>

                    <!-- Shortcut card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Red}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="keyboard" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Global shortcut" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Press to open Arc anywhere" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{DynamicResource Depth3}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="7" Padding="10,4">
                                            <TextBlock Text="{Binding Shortcut}" FontFamily="{DynamicResource MonoFont}" FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                        </Border>
                                        <Button x:Name="EditShortcutBtn" Content="Edit" Click="OnEditShortcutClick"
                                                Style="{StaticResource GhostBtn}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="minimize-2" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Minimize to tray" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Close goes to tray instead of quitting" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding MinimizeToTray, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="ShortcutConflict"
                               Text="⚠ This shortcut may conflict with another app"
                               FontFamily="{DynamicResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource Red}" Visibility="Collapsed" Margin="4,6,0,0"/>

                    <!-- Group: Privacy -->
                    <TextBlock Text="PRIVACY" Style="{StaticResource GroupLabel}"/>

                    <!-- Privacy card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentIp}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="shield" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Clear clipboard on exit" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Wipes clipboard history when Arc closes" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding ClearClipboardOnExit, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Red}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="trash-2" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Clear history" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Permanently erase all launch history" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Clear history"
                                            Command="{Binding ClearAllHistoryCommand}"
                                            Style="{StaticResource DangerBtn}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>


                <!-- ════════════════════ Actions ════════════════════════ -->
                <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibility}, ConverterParameter=Actions}">

                    <TextBlock Text="QUICK ACTIONS" Style="{StaticResource GroupLabel}" Margin="4,4,0,6"/>

                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentCalculator}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="calculator" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Calculator &amp; converter" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                                        <local:ToggleSwitch IsOn="{Binding ActionCalc, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Math" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionCurrency, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Currency" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentTime}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="clock" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Tools" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                                        <local:ToggleSwitch IsOn="{Binding ActionTimer, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Timer" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionColor, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Color" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionPasswordGen, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Passwords" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentIp}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="network" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="System tools" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                                        <local:ToggleSwitch IsOn="{Binding ActionIp, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="IP" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionKillProcess, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Kill" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionScreenshot, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Screenshot" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="AI &amp; notes" Style="{StaticResource SectionTitle}"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                                        <local:ToggleSwitch IsOn="{Binding ActionAi, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="AI chat" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,12,0"/>
                                        <local:ToggleSwitch IsOn="{Binding ActionQuickNote, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Quick note" Style="{StaticResource SettingDesc}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Green}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="power" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="System commands" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Shutdown, restart, sleep, lock" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <local:ToggleSwitch Grid.Column="2" IsOn="{Binding ActionSystem, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ════════════════════ Advanced ════════════════════════ -->
                <StackPanel Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibility}, ConverterParameter=Advanced}">

                    <TextBlock Text="AI PROVIDER" Style="{StaticResource GroupLabel}" Margin="4,4,0,6"/>

                    <!-- AI Provider card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="AI Provider" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Backend and model for AI chat" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ComboBox ItemsSource="{Binding Providers}"
                                                  SelectedItem="{Binding AiProvider, Mode=TwoWay}"
                                                  Width="110" Height="28" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding CurrentModels}"
                                                  SelectedItem="{Binding AiModel, Mode=TwoWay}"
                                                  Width="120" Height="28" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <!-- API Key row -->
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentFiles}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="key" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="API key" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Stored locally with Windows user encryption" Style="{StaticResource SettingDesc}"/>
                                        <Border Background="{DynamicResource Depth3}" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="7"
                                                Margin="0,8,0,0" Padding="10,0" Height="32">
                                            <PasswordBox x:Name="AiApiKeyBox"
                                                         PasswordChanged="OnAiApiKeyChanged"
                                                         FontFamily="{DynamicResource UIFont}" FontSize="12"
                                                         Background="Transparent" BorderThickness="0"
                                                         VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="MAINTENANCE" Style="{StaticResource GroupLabel}"/>

                    <!-- App catalog + About card -->
                    <Border Style="{StaticResource SettingCard}">
                        <StackPanel>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource AccentCalculator}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="refresh-cw" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="App catalog" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="Refresh when newly installed apps don't appear" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Refresh"
                                            Command="{Binding RefreshAppsCommand}"
                                            Style="{StaticResource GhostBtn}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource RowDivider}"/>
                            <Border Style="{StaticResource CardRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource IconContainer}">
                                        <Path Width="14" Height="14" Stretch="Uniform"
                                              Stroke="{DynamicResource Green}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Data>
                                                <Binding Source="info" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                            </Path.Data>
                                        </Path>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="About Arc" Style="{StaticResource SectionTitle}"/>
                                        <TextBlock Text="v0.2.0 · MIT License" Style="{StaticResource SettingDesc}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</UserControl>
