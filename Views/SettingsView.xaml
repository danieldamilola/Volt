<UserControl x:Class="Volt.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt.Views">

    <UserControl.Resources>

        <!-- Section label -->
        <Style x:Key="SH" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize"    Value="{DynamicResource FontXs}"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,20,0,6"/>
        </Style>

        <!-- Row label (left side of a row) -->
        <Style x:Key="RL" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="{DynamicResource UIFont}"/>
            <Setter Property="FontSize"          Value="{DynamicResource FontBase}"/>
            <Setter Property="FontWeight"        Value="Medium"/>
            <Setter Property="Foreground"        Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Segmented pill container -->
        <Style x:Key="Seg" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource SurfaceLow}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding"      Value="2"/>
        </Style>

        <!-- Card (group of rows with a border) -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="{DynamicResource RadiusRow}"/>
        </Style>

        <!-- Inner row divider (full-bleed) -->
        <Style x:Key="Div" TargetType="Border">
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <!-- Icon-only button (browse folder / add) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="16,0">
            <TextBlock Text="Settings"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontBase}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <Button Click="OnCloseClick"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="28" Height="28"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" FocusVisualStyle="{x:Null}"
                    ToolTip="Close (Esc)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <Path Data="M18 6L6 18M6 6l12 12"
                                  Width="12" Height="12" Stretch="Uniform"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <!-- ══ SCROLL CONTENT ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,0,16,24">

                <!-- ─────────────────────────────────── APPEARANCE ───── -->
                <TextBlock Text="APPEARANCE" Style="{StaticResource SH}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Theme -->
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Theme" Style="{StaticResource RL}"/>
                            <Border Grid.Column="1" Style="{StaticResource Seg}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="Dark"   IsChecked="{Binding ThemeDark}"   Style="{StaticResource SegmentedRadio}" GroupName="Theme" Background="{Binding BackgroundColor, Converter={StaticResource HexToColorConverter}}"/>
                                    <RadioButton Content="Light"  IsChecked="{Binding ThemeLight}"  Style="{StaticResource SegmentedRadio}" GroupName="Theme" Background="{Binding BackgroundColor, Converter={StaticResource HexToColorConverter}}"/>
                                    <RadioButton Content="System" IsChecked="{Binding ThemeSystem}" Style="{StaticResource SegmentedRadio}" GroupName="Theme" Background="{Binding BackgroundColor, Converter={StaticResource HexToColorConverter}}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Div}" Margin="14,0"/>

                        <!-- Blur effect -->
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Blur effect" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding EnableBlur, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>

                        <!-- Window opacity -->
                        <Grid MinHeight="52" Margin="14,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Window opacity" Style="{StaticResource RL}"/>
                                <TextBlock Text="Adjust transparency of the search bar"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="{DynamicResource FontXs}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Seg}" VerticalAlignment="Center">
                                <Slider Width="120" Minimum="0.5" Maximum="1.0" Value="{Binding WindowOpacity, Mode=TwoWay}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                            </Border>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>

                        <!-- Background color -->
                        <Grid MinHeight="52" Margin="14,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Background color" Style="{StaticResource RL}"/>
                                <TextBlock Text="Set the base color of the search bar"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="{DynamicResource FontXs}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="32" Height="32" CornerRadius="6" Margin="0,0,8,0" Background="{Binding BackgroundColor, Converter={StaticResource HexToColorConverter}}"/>
                                <Border Style="{StaticResource Seg}">
                                    <TextBox Width="100" Text="{Binding BackgroundColor, Mode=TwoWay}" FontFamily="{DynamicResource UIFont}" FontSize="{DynamicResource FontSm}" Padding="8,4"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>

                        <!-- Accent color -->
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Accent color" Style="{StaticResource RL}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource Seg}">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="Follow Windows" IsChecked="{Binding UseWindowsAccentColor}" Style="{StaticResource SegmentedRadio}" GroupName="Accent"/>
                                        <RadioButton Content="Custom"         IsChecked="{Binding UseCustomAccentColor}"  Style="{StaticResource SegmentedRadio}" GroupName="Accent"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource SurfaceLow}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Height="28" Width="68" Margin="6,0,0,0"
                                        Padding="6,0">
                                    <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=LostFocus}"
                                             VerticalContentAlignment="Center"
                                             FontFamily="{DynamicResource MonoFont}"
                                             FontSize="{DynamicResource FontXs}"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Background="Transparent" BorderThickness="0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseWindowsAccentColor}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity"   Value="0.3"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource Div}" Margin="14,0"/>

                        <!-- Launcher width -->
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Launcher width" Style="{StaticResource RL}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider Value="{Binding LauncherWidth, Mode=TwoWay, Delay=500}"
                                        Minimum="500" Maximum="900"
                                        Width="130" SmallChange="10" LargeChange="50"/>
                                <TextBlock Text="{Binding LauncherWidth, StringFormat='{}{0:0} px'}"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="{DynamicResource FontSm}"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" Width="46"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────── SEARCH ───── -->
                <TextBlock Text="SEARCH" Style="{StaticResource SH}"/>

                <!-- What to search -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Height="44" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Apps"      Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding IndexApps,      Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="44" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Files"     Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding IndexFiles,     Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="44" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Folders"   Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding IndexFolders,   Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="44" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Clipboard" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding IndexClipboard, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Folders to include -->
                <TextBlock Text="SEARCH FOLDERS" Style="{StaticResource SH}"/>
                <ItemsControl ItemsSource="{Binding IndexedFoldersList}" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="32" Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2"
                                        Background="{DynamicResource SurfaceLow}"
                                        CornerRadius="6"/>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="{DynamicResource FontSm}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource IconBtn}"
                                        Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Path Data="M18 6L6 18M6 6l12 12"
                                          Width="8" Height="8" Stretch="Uniform"
                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Add folder row -->
                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="3"
                            Background="{DynamicResource SurfaceLow}"
                            CornerRadius="6"/>
                    <TextBox x:Name="FolderPathBox"
                             Grid.Column="0"
                             Text="{Binding NewFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             FontFamily="{DynamicResource UIFont}"
                             FontSize="{DynamicResource FontSm}"
                             Foreground="{DynamicResource TextSecondary}"
                             Background="Transparent" BorderThickness="0"
                             Margin="10,0,0,0"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource IconBtn}"
                            Click="OnBrowseFolderClick"
                            ToolTip="Browse…">
                        <Path Data="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"
                              Width="14" Height="14" Stretch="Uniform"
                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" Fill="Transparent"/>
                    </Button>
                    <Button Grid.Column="2"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding AddFolderCommand}"
                            ToolTip="Add folder">
                        <Path Data="M12 5v14M5 12h14"
                              Width="12" Height="12" Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </Grid>

                <!-- File types -->
                <TextBlock Text="FILE TYPES" Style="{StaticResource SH}"/>
                <ItemsControl ItemsSource="{Binding FileTypesList}" Margin="0,0,0,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceLow}"
                                    CornerRadius="4" Margin="0,0,4,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{DynamicResource MonoFont}"
                                               FontSize="{DynamicResource FontXs}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"
                                               Margin="7,4,2,4"/>
                                    <Button Style="{StaticResource IconBtn}"
                                            Width="20" Height="20"
                                            Command="{Binding DataContext.RemoveFileTypeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="M18 6L6 18M6 6l12 12"
                                              Width="7" Height="7" Stretch="Uniform"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Add file type -->
                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.ColumnSpan="2"
                            Background="{DynamicResource SurfaceLow}"
                            CornerRadius="6"/>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewFileType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             FontFamily="{DynamicResource MonoFont}"
                             FontSize="{DynamicResource FontSm}"
                             Foreground="{DynamicResource TextSecondary}"
                             Background="Transparent" BorderThickness="0"
                             Margin="10,0,0,0"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource IconBtn}"
                            Command="{Binding AddFileTypeCommand}"
                            ToolTip="Add extension">
                        <Path Data="M12 5v14M5 12h14"
                              Width="12" Height="12" Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </Grid>

                <!-- Fuzzy search -->
                <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                    <Grid Height="48" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fuzzy search" Style="{StaticResource RL}"/>
                        <local:ToggleSwitch Grid.Column="1" IsOn="{Binding FuzzySearch, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ──────────────────────────────────────── HOTKEY ───── -->
                <TextBlock Text="HOTKEY" Style="{StaticResource SH}"/>
                <Border Style="{StaticResource Card}">
                    <Grid Height="48" Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Shortcut" Style="{StaticResource RL}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource SurfaceLow}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Height="28" Padding="10,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ShortcutDisplay"
                                           Text="{Binding Shortcut}"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="{DynamicResource FontSm}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button x:Name="EditShortcutBtn"
                                    Content="Edit"
                                    Click="OnEditShortcutClick"
                                    Height="28" Padding="10,0"
                                    Margin="8,0,0,0"
                                    FontFamily="{DynamicResource UIFont}"
                                    FontSize="{DynamicResource FontSm}"
                                    Foreground="{DynamicResource TextSecondary}"
                                    Background="{DynamicResource SurfaceLow}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Conflict warning -->
                <TextBlock x:Name="ShortcutConflict"
                           Text="⚠ This shortcut may conflict with another app"
                           FontFamily="{DynamicResource UIFont}"
                           FontSize="{DynamicResource FontXs}"
                           Foreground="{DynamicResource Red}"
                           Visibility="Collapsed"
                           Margin="0,-2,0,0"/>

                <!-- ──────────────────────────────────────── SYSTEM ───── -->
                <TextBlock Text="SYSTEM" Style="{StaticResource SH}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Launch on startup" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding LaunchOnStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Hide to tray" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding MinimizeToTray, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Show tray icon" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding ShowTrayIcon, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid MinHeight="52" Margin="14,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Scan for new apps" Style="{StaticResource RL}"/>
                                <TextBlock Text="How often Volt re-discovers installed apps"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="{DynamicResource FontXs}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Style="{StaticResource Seg}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="3h"     IsChecked="{Binding ReIndex3h}"     Style="{StaticResource SegmentedRadio}" GroupName="ReIdx"/>
                                    <RadioButton Content="6h"     IsChecked="{Binding ReIndex6h}"     Style="{StaticResource SegmentedRadio}" GroupName="ReIdx"/>
                                    <RadioButton Content="12h"    IsChecked="{Binding ReIndex12h}"    Style="{StaticResource SegmentedRadio}" GroupName="ReIdx"/>
                                    <RadioButton Content="Manual" IsChecked="{Binding ReIndexManual}" Style="{StaticResource SegmentedRadio}" GroupName="ReIdx"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────── PRIVACY ───── -->
                <TextBlock Text="PRIVACY" Style="{StaticResource SH}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Clear clipboard on exit" Style="{StaticResource RL}"/>
                            <local:ToggleSwitch Grid.Column="1" IsOn="{Binding ClearClipboardOnExit, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Style="{StaticResource Div}" Margin="14,0"/>
                        <Grid Height="48" Margin="14,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Clear all history" Style="{StaticResource RL}"/>
                                <TextBlock Text="Frequency data, clipboard, recent files"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="{DynamicResource FontXs}"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Clear"
                                    Command="{Binding ClearAllHistoryCommand}"
                                    Height="28" Padding="12,0"
                                    FontFamily="{DynamicResource UIFont}"
                                    FontSize="{DynamicResource FontSm}"
                                    Foreground="{DynamicResource Red}"
                                    Background="{DynamicResource SurfaceLow}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Version stamp -->
                <TextBlock Text="Volt v0.2.0 · MIT License"
                           FontFamily="{DynamicResource UIFont}"
                           FontSize="{DynamicResource FontXs}"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
