<Window x:Class="Arc.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Arc.Converters"
        Title="Welcome to Arc"
        Width="540"
        Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="OnDrag">

    <Window.Resources>
        <Storyboard x:Key="SlideIn" Duration="0:0:0.35">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1"
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border Background="{DynamicResource Void}"
            CornerRadius="16"
            BorderBrush="{DynamicResource BorderStrong}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="12" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content area -->
            <Grid Grid.Row="0" Margin="48,40,48,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══════════════════ Slide 1: Welcome ═════════════ -->
                <StackPanel x:Name="Slide1" Grid.Row="0" VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </StackPanel.RenderTransform>

                    <!-- Arc icon -->
                    <Border Width="56" Height="56" CornerRadius="16"
                            Background="{DynamicResource Depth2}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Path Width="24" Height="24" Stretch="Uniform"
                              Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Data>
                                <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                            </Path.Data>
                        </Path>
                    </Border>

                    <TextBlock Text="Welcome to Arc"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="A faster way to work on Windows."
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Arc bar mockup -->
                    <Border Background="{DynamicResource Depth1}"
                            CornerRadius="28"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="0"
                            Height="56"
                            Margin="20,0"
                            HorizontalAlignment="Stretch">
                        <Grid Margin="18,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent" VerticalAlignment="Center">
                                    <Path.Data>
                                        <Binding Source="search" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                    </Path.Data>
                                </Path>
                                <TextBlock Text="  Search anything…"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="15"
                                           Foreground="{DynamicResource TextTertiary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right"
                                    Background="{DynamicResource Accent}"
                                    CornerRadius="20"
                                    Padding="12,4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Alt+Space"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextInverse}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock Text="Press Alt+Space to open. Type to search. Enter to launch."
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- ═════════════════ Slide 2: Categories ════════════ -->
                <StackPanel x:Name="Slide2" Grid.Row="0" VerticalAlignment="Center"
                            Visibility="Collapsed"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </StackPanel.RenderTransform>

                    <TextBlock Text="Three ways to browse"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Hover over the bar to reveal category shortcuts."
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <!-- Category cards -->
                    <StackPanel Margin="20,0" HorizontalAlignment="Center">

                        <!-- Files -->
                        <Border Background="{DynamicResource Depth2}"
                                CornerRadius="10" Padding="16,12" Margin="0,0,0,10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="{DynamicResource Depth3}" Margin="0,0,14,0">
                                    <Path Width="16" Height="16" Stretch="Uniform"
                                          Stroke="{DynamicResource AccentFiles}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" Fill="Transparent"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Data>
                                            <Binding Source="folder" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Files" FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Browse recent files and folders"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Clipboard -->
                        <Border Background="{DynamicResource Depth2}"
                                CornerRadius="10" Padding="16,12" Margin="0,0,0,10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="{DynamicResource Depth3}" Margin="0,0,14,0">
                                    <Path Width="16" Height="16" Stretch="Uniform"
                                          Stroke="{DynamicResource AccentClipboard}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Data>
                                            <Binding Source="clipboard" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Clipboard" FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Access your copy history"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Actions -->
                        <Border Background="{DynamicResource Depth2}"
                                CornerRadius="10" Padding="16,12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="{DynamicResource Depth3}" Margin="0,0,14,0">
                                    <Path Width="16" Height="16" Stretch="Uniform"
                                          Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Data>
                                            <Binding Source="zap" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Actions" FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Calculator, AI, Timer &amp; more"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Or just type — Arc searches everything."
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- ═════════════════ Slide 3: Done ══════════════════ -->
                <StackPanel x:Name="Slide3" Grid.Row="0" VerticalAlignment="Center"
                            Visibility="Collapsed"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </StackPanel.RenderTransform>

                    <Border Width="56" Height="56" CornerRadius="16"
                            Background="{DynamicResource Depth2}"
                            BorderBrush="{DynamicResource Accent}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Path Width="24" Height="24" Stretch="Uniform"
                              Stroke="{DynamicResource Accent}" StrokeThickness="2"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Data>
                                <Binding Source="check" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                            </Path.Data>
                        </Path>
                    </Border>

                    <TextBlock Text="You're all set"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Arc is ready. Press Alt+Space to launch."
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <Border Background="{DynamicResource Depth2}"
                            CornerRadius="10" Padding="20,16"
                            HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Settings anytime"
                                       FontFamily="{DynamicResource UIFont}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource Depth3}"
                                    CornerRadius="6" Padding="12,4"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Ctrl + ,"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource Accent}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Bottom bar: dots + button -->
            <Grid Grid.Row="1" Margin="48,0,48,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Dots -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{DynamicResource Accent}"/>
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{DynamicResource BorderStrong}"/>
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{DynamicResource BorderStrong}"/>
                </StackPanel>

                <!-- Button -->
                <Button Grid.Column="1"
                        x:Name="NextButton"
                        Content="Get Started"
                        FontFamily="{DynamicResource UIFont}"
                        FontSize="13"
                        FontWeight="Medium"
                        Background="{DynamicResource Accent}"
                        Foreground="{DynamicResource Void}"
                        BorderThickness="0"
                        Padding="24,10"
                        Cursor="Hand"
                        Click="OnNextClick">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
