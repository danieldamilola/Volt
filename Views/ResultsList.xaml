<UserControl x:Class="Volt.Views.ResultsList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt.Views"
             xmlns:models="clr-namespace:Volt.Models"
             xmlns:conv="clr-namespace:Volt.Converters">

    <UserControl.Resources>

        <!-- Section label -->
        <DataTemplate x:Key="SectionTemplate" DataType="{x:Type models:SectionLabel}">
            <TextBlock Text="{Binding Title}"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="10"
                       FontWeight="Medium"
                       Foreground="{DynamicResource TextMuted}"
                       Opacity="0.65"
                       Padding="14,11,14,3"
                       TextOptions.TextFormattingMode="Display"/>
        </DataTemplate>

        <!-- Result row -->
        <DataTemplate x:Key="ResultTemplate" DataType="{x:Type models:SearchResult}">
            <Grid x:Name="RowRoot"
                  Height="46"
                  Margin="6,1"
                  Background="Transparent"
                  MouseLeftButtonDown="OnRowClick"
                  Cursor="Hand">

                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Run as Administrator"
                                  Command="{Binding DataContext.RunAsAdminCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Shift+Enter"/>
                        <MenuItem Header="Open file location"
                                  Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Enter"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- Full-width row background -->
                <Border x:Name="RowBg" CornerRadius="9" Background="Transparent"/>

                <!-- Content -->
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>    <!-- icon -->
                        <ColumnDefinition Width="11"/>    <!-- gap -->
                        <ColumnDefinition Width="*"/>     <!-- text -->
                        <ColumnDefinition Width="Auto"/>  <!-- hint -->
                    </Grid.ColumnDefinitions>

                    <!-- App / file icon — transparent container, icon floats naturally -->
                    <Border x:Name="ImgBox"
                            Grid.Column="0"
                            Width="30" Height="30"
                            CornerRadius="7"
                            Background="Transparent"
                            VerticalAlignment="Center">
                        <Image x:Name="AppIcon"
                               Width="20" Height="20"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <Binding Path="IconPath">
                                    <Binding.Converter>
                                        <conv:PathToIconConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Image.Source>
                        </Image>
                    </Border>

                    <!-- Lucide icon — shown when no file icon is available -->
                    <Border x:Name="LucideBox"
                            Grid.Column="0"
                            Width="30" Height="30"
                            CornerRadius="7"
                            Background="{DynamicResource SurfaceLow}"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <Path x:Name="LucideIconPath"
                              Width="14" Height="14"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Path.Data>
                                <Binding Path="LucideIcon">
                                    <Binding.Converter>
                                        <conv:LucideIconConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Path.Data>
                        </Path>
                    </Border>

                    <!-- Name + subtitle -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   Text="{Binding Name}"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="SubtitleText"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   Opacity="0.8"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Text>
                                <Binding Path="Subtitle">
                                    <Binding.Converter>
                                        <conv:PathTrimConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Enter hint — only on selected row -->
                    <Border x:Name="EnterHint"
                            Grid.Column="3"
                            CornerRadius="4"
                            Background="{DynamicResource Surface}"
                            Padding="5,2"
                            Margin="8,0,0,0"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                        <TextBlock Text="↵"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </Border>
                </Grid>
            </Grid>

            <DataTemplate.Triggers>

                <!-- Hover -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                    <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource HoverBg}"/>
                </DataTrigger>

                <!-- Selected -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="RowBg"        Property="Background" Value="{DynamicResource SelectedBg}"/>
                    <Setter TargetName="EnterHint"    Property="Visibility" Value="Visible"/>
                    <Setter TargetName="NameText"     Property="Foreground" Value="{DynamicResource SelectedText}"/>
                    <Setter TargetName="SubtitleText" Property="Foreground" Value="{DynamicResource SelectedMuted}"/>
                    <Setter TargetName="SubtitleText" Property="Opacity"    Value="1"/>
                    <Setter TargetName="LucideBox"    Property="Background" Value="{DynamicResource SurfaceLow}"/>
                    <Setter TargetName="LucideIconPath" Property="Stroke"   Value="{DynamicResource SelectedText}"/>
                </DataTrigger>

                <!-- No file icon → use Lucide fallback -->
                <DataTrigger Binding="{Binding IconPath}" Value="{x:Null}">
                    <Setter TargetName="ImgBox"   Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="LucideBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>

            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Template selector -->
        <local:ResultTemplateSelector x:Key="TemplateSelector"
                                      SectionTemplate="{StaticResource SectionTemplate}"
                                      ResultTemplate="{StaticResource ResultTemplate}"/>
    </UserControl.Resources>

    <ListBox x:Name="ResultsBox"
             ItemsSource="{Binding Results}"
             ItemTemplateSelector="{StaticResource TemplateSelector}"
             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
             SelectionChanged="OnSelectionChanged"
             HorizontalContentAlignment="Stretch"
             Padding="0,4,0,8"
             Focusable="False"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.CanContentScroll="False"/>
</UserControl>
