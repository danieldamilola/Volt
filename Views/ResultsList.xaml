<UserControl x:Class="Arc.Views.ResultsList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Arc.Views"
             xmlns:models="clr-namespace:Arc.Models"
             xmlns:conv="clr-namespace:Arc.Converters">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>

        <!-- Section label (generic) -->
        <DataTemplate x:Key="SectionTemplate" DataType="{x:Type models:SectionLabel}">
            <Grid Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Title}"
                           FontFamily="{DynamicResource UIFont}"
                           FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextTertiary}"
                           Opacity="0.65"
                           Padding="12,10,12,4"
                           TextOptions.TextFormattingMode="Display"/>
                <!-- Clear all button — only shown on CLIPBOARD section label -->
                <Button Grid.Column="1"
                        Content="Clear all"
                        FontFamily="{DynamicResource UIFont}"
                        FontSize="10"
                        Foreground="{DynamicResource TextMuted}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,3,10,0"
                        VerticalAlignment="Bottom"
                        Command="{Binding DataContext.ClearClipboardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        FocusVisualStyle="{x:Null}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Title}" Value="CLIPBOARD">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Result row -->
        <DataTemplate x:Key="ResultTemplate" DataType="{x:Type models:SearchResult}">
            <Grid x:Name="RowRoot"
                  Height="{DynamicResource RowHeight}"
                  Margin="8,1"
                  Background="Transparent"
                  ToolTip="{Binding DetailText}"
                  MouseLeftButtonDown="OnRowClick"
                  Cursor="Hand">

                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Run as Administrator"
                                  Command="{Binding DataContext.RunAsAdminCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Shift+Enter"/>
                        <MenuItem Header="Open file location"
                                  Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  InputGestureText="Ctrl+Enter"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- Full-width row background -->
                <Border x:Name="RowBg" CornerRadius="{DynamicResource RadiusRow}" Background="Transparent"/>

                <!-- Content -->
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>    <!-- icon -->
                        <ColumnDefinition Width="8"/>     <!-- gap -->
                        <ColumnDefinition Width="*"/>     <!-- text -->
                        <ColumnDefinition Width="Auto"/>  <!-- hint -->
                    </Grid.ColumnDefinitions>

                    <!-- App / file icon — transparent container, icon floats naturally -->
                    <Border x:Name="ImgBox"
                            Grid.Column="0"
                            Width="32" Height="32"
                            CornerRadius="{DynamicResource RadiusSm}"
                            Background="Transparent"
                            VerticalAlignment="Center">
                        <Image x:Name="AppIcon"
                               Width="20" Height="20"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <Binding Path="IconPath">
                                    <Binding.Converter>
                                        <conv:PathToIconConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Image.Source>
                        </Image>
                    </Border>

                    <!-- Lucide icon — shown when no file icon is available -->
                    <Border x:Name="LucideBox"
                            Grid.Column="0"
                            Width="32" Height="32"
                            CornerRadius="{DynamicResource RadiusSm}"
                            Background="{DynamicResource SurfaceLow}"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <Path x:Name="LucideIconPath"
                              Width="14" Height="14"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Path.Data>
                                <Binding Path="LucideIcon">
                                    <Binding.Converter>
                                        <conv:LucideIconConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Path.Data>
                        </Path>
                    </Border>

                    <!-- Name + subtitle -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="NameText"
                                   Text="{Binding Name}"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="SubtitleText"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Opacity="0.8"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Text>
                                <Binding Path="DisplaySubtitle"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Enter hint — only on selected row -->
                    <Border x:Name="EnterHint"
                            Grid.Column="3"
                            CornerRadius="4"
                            Background="{DynamicResource Depth2}"
                            Padding="5,2"
                            Margin="8,0,0,0"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                        <TextBlock Text="↵"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </Border>

                    <!-- Clipboard action buttons — pin + delete, shown on hover for clipboard items -->
                    <StackPanel x:Name="ClipActions"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="4,0,0,0"
                                Visibility="Collapsed">

                        <!-- Pin/Unpin button — Tag={IsPinned} so ControlTemplate can read it -->
                        <Button x:Name="PinBtn"
                                Width="26" Height="26"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" FocusVisualStyle="{x:Null}"
                                ToolTip="Pin"
                                Tag="{Binding IsPinned}"
                                Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="5">
                                        <Path Width="11" Height="11" Stretch="Uniform"
                                              x:Name="PinPath"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Data="M12 2l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6z"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Depth3}"/>
                                        </Trigger>
                                        <!-- Pinned state: fill the icon in accent color -->
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                            <Setter TargetName="PinPath" Property="Fill"   Value="{DynamicResource Accent}"/>
                                            <Setter TargetName="PinPath" Property="Stroke" Value="{DynamicResource Accent}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Delete single item button -->
                        <Button Width="26" Height="26"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" FocusVisualStyle="{x:Null}"
                                ToolTip="Remove"
                                Click="OnClipDeleteClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="5">
                                        <Path Width="11" Height="11" Stretch="Uniform"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Data="M3 6h18M19 6l-1 14H6L5 6M9 6V4h6v2"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Depth3}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>
            </Grid>

            <DataTemplate.Triggers>

                <!-- Hover: animate background to HoverBg over 80ms (only when not selected) -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RowBg"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#18181B" Duration="0:0:0.08"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <!-- Selected: animate background over 100ms. Selection is its own signal — no text changes. -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RowBg"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#1F1F23" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RowBg"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#00000000" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <!-- Normal: not hovered, not selected — animate background to transparent over 100ms -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="False"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RowBg"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#00000000" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>

                <!-- No file icon → use Lucide fallback -->
                <DataTrigger Binding="{Binding IconPath}" Value="{x:Null}">
                    <Setter TargetName="ImgBox"   Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="LucideBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <!-- Show clipboard action buttons on hover -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True"/>
                        <Condition Binding="{Binding Type}" Value="Clipboard"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ClipActions" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="EnterHint"   Property="Visibility" Value="Collapsed"/>
                </MultiDataTrigger>


            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Template selector -->
        <local:ResultTemplateSelector x:Key="TemplateSelector"
                                      SectionTemplate="{StaticResource SectionTemplate}"
                                      ResultTemplate="{StaticResource ResultTemplate}"/>
    </UserControl.Resources>

    <ListBox x:Name="ResultsBox"
             ItemsSource="{Binding Results}"
             ItemTemplateSelector="{StaticResource TemplateSelector}"
             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
             SelectionChanged="OnSelectionChanged"
             HorizontalContentAlignment="Stretch"
             Padding="0,4,0,8"
             Focusable="False"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.CanContentScroll="False"/>
</UserControl>
