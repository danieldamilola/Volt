<UserControl x:Class="Arc.Views.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Arc.ViewModels"
             xmlns:conv="clr-namespace:Arc.Converters">

    <UserControl.Resources>

        <!-- Bool → Visibility converters used by AI buttons -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="StringToVisibility"/>

        <!-- ── User message bubble (right-aligned) ──────────────────── -->
        <DataTemplate x:Key="UserBubble">
            <Grid Margin="0,0,0,14">
                <Border HorizontalAlignment="Right"
                        Background="{DynamicResource Depth3}"
                        BorderBrush="{DynamicResource BorderStrong}"
                        BorderThickness="1"
                        CornerRadius="14,14,4,14"
                        Padding="12,9"
                        MaxWidth="340">
                    <TextBlock Text="{Binding Content}"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               LineHeight="19"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── AI message bubble (left-aligned) ─────────────────────── -->
        <DataTemplate x:Key="AiBubble">
            <Grid Margin="0,0,0,14">
                <StackPanel HorizontalAlignment="Left" MaxWidth="380">
                    <!-- AI label -->
                    <TextBlock Text="ARC AI"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="2,0,0,4"/>
                    <Border Background="{DynamicResource Depth2}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4,14,14,14"
                            Padding="12,9">
                        <TextBlock Text="{Binding Content}"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextWrapping="Wrap"
                                   LineHeight="19"/>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{DynamicResource PreviewBg}"
            BorderBrush="{DynamicResource BorderStrong}"
            BorderThickness="0"
            Padding="20"
            PreviewMouseWheel="OnPreviewMouseWheel">

        <!-- Grid wrapping all panels so Border only has one child -->
        <Grid>

        <!-- Calculator -->
        <Grid x:Name="CalcPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       x:Name="CalcExprText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontMono13}"
                       Foreground="{DynamicResource TextMuted}"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1"
                       x:Name="CalcResultText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXxl}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Green}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="2"
                       Text="↵ copy"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXs}"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Color -->
        <Grid x:Name="ColorPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="ColorSwatch"
                    Width="80" Height="80"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="1"
                       x:Name="ColorHexText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXl}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,8"/>

            <StackPanel Grid.Row="2">
                <TextBlock x:Name="ColorRgbText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="{DynamicResource FontSm}"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock x:Name="ColorHslText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="{DynamicResource FontSm}"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Timer -->
        <Grid x:Name="TimerPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       x:Name="TimerCountdown"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontDisplay}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Progress bar -->
            <Border Grid.Row="1"
                    Height="6"
                    CornerRadius="3"
                    Background="{DynamicResource SurfaceLow}"
                    Margin="0,16,0,0">
                <Border x:Name="TimerBar"
                        CornerRadius="3"
                        Background="{DynamicResource Accent}"
                        HorizontalAlignment="Left"/>
            </Border>

            <TextBlock Grid.Row="2"
                       x:Name="TimerStatus"
                       Text="Press ↵ to start"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontSm}"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

            <Button Grid.Row="3"
                    x:Name="CancelTimerBtn"
                    Content="Cancel"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0"
                    Visibility="Collapsed"
                    Click="OnCancelTimer"/>
        </Grid>

        <!-- IP Address -->
        <Grid x:Name="IpPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LOCAL"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontXs}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}"/>
            <TextBlock Grid.Row="1"
                       x:Name="IpLocalText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontIp}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,4,0,0"/>

            <TextBlock Grid.Row="3"
                       Text="PUBLIC"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontXs}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}"/>
            <TextBlock Grid.Row="4"
                       x:Name="IpPublicText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontIp}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,4,0,0"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             AI PANEL — Completely recoded
             ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="AiPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <!-- Header bar -->
                <RowDefinition Height="Auto"/>
                <!-- Separator -->
                <RowDefinition Height="1"/>
                <!-- Message area -->
                <RowDefinition Height="*"/>
                <!-- Error bar -->
                <RowDefinition Height="Auto"/>
                <!-- Input area -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0"
                        Width="28" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                        Click="OnAiBack"
                        ToolTip="Back (Esc)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                                <Path Width="13" Height="13" Stretch="Uniform"
                                      Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Path.Data>
                                        <Binding Source="arrow-left" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                    </Path.Data>
                                </Path>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Title area -->
                <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                    <TextBlock Text="Arc AI"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel x:Name="AiActions" Grid.Column="2" Orientation="Horizontal"
                            Visibility="Collapsed" VerticalAlignment="Center">
                    <!-- Copy conversation -->
                    <Button Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                            Click="OnAiCopy"
                            ToolTip="Copy conversation">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                                    <Path Width="13" Height="13" Stretch="Uniform"
                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Data>
                                            <Binding Source="copy" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Margin="0,8,0,0"/>

            <!-- ── Message list ────────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="0,12,0,0">

                <!-- Empty state — shown when no conversation yet -->
                <Border x:Name="AiEmptyPrompt"
                        VerticalAlignment="Center"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Sparkle icon -->
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{DynamicResource Depth3}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,14">
                            <Path Width="20" Height="20" Stretch="Uniform"
                                  Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path.Data>
                                    <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                </Path.Data>
                            </Path>
                        </Border>
                        <TextBlock Text="Ask anything"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Type a question and press Enter"
                                   FontFamily="{DynamicResource UIFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Conversation scroll view -->
                <ScrollViewer x:Name="AiScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,0,4,8">
                    <ItemsControl x:Name="ChatMessages" ItemsSource="{Binding AiConversation}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <!-- USER MESSAGE -->
                                                <DataTrigger Binding="{Binding Item1}" Value="user">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,18">
                                                                    <Border HorizontalAlignment="Right"
                                                                            Background="{DynamicResource Depth3}"
                                                                            CornerRadius="16,16,4,16"
                                                                            Padding="14,10"
                                                                            MaxWidth="340">
                                                                        <TextBlock Text="{Binding Item2}"
                                                                                   FontFamily="{DynamicResource UIFont}"
                                                                                   FontSize="13"
                                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                                   TextWrapping="Wrap"
                                                                                   LineHeight="20"/>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <!-- ASSISTANT MESSAGE -->
                                                <DataTrigger Binding="{Binding Item1}" Value="assistant">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,24">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <!-- AI Icon -->
                                                                    <Border Grid.Column="0" Width="24" Height="24"
                                                                            CornerRadius="12"
                                                                            Background="{DynamicResource Depth3}"
                                                                            VerticalAlignment="Top"
                                                                            Margin="0,0,12,0">
                                                                        <Path Width="12" Height="12" Stretch="Uniform"
                                                                              Stroke="{DynamicResource TextPrimary}" StrokeThickness="1.5"
                                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                                              Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <Path.Data>
                                                                                <Binding Source="sparkles" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                                                            </Path.Data>
                                                                        </Path>
                                                                    </Border>
                                                                    
                                                                    <!-- Content -->
                                                                    <TextBlock Grid.Column="1" Text="{Binding Item2}"
                                                                               FontFamily="{DynamicResource UIFont}"
                                                                               FontSize="13"
                                                                               Foreground="{DynamicResource TextPrimary}"
                                                                               TextWrapping="Wrap"
                                                                               LineHeight="21"
                                                                               Margin="0,2,0,0"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>

            <!-- ── Error bar ────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    x:Name="AiErrorBar"
                    Background="{DynamicResource Depth2}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,7"
                    Margin="0,8,0,0"
                    Visibility="{Binding AiError, Converter={StaticResource StringToVisibility}}">
                <TextBlock x:Name="AiErrorText"
                           Text="{Binding AiError}"
                           FontFamily="{DynamicResource UIFont}"
                           FontSize="11"
                           Foreground="{DynamicResource Red}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ── Input area ────────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="{DynamicResource Depth2}"
                    BorderBrush="{DynamicResource BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Text input -->
                    <TextBox x:Name="AiFollowUp"
                             Grid.Column="0"
                             FontFamily="{DynamicResource UIFont}"
                             FontSize="13"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="14,10"
                             VerticalAlignment="Center"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="42"
                             MaxHeight="120"
                             PreviewKeyDown="OnAiFollowUpPreviewKeyDown"
                             GotFocus="OnAiFollowUpFocus"
                             Text="Message Arc AI…"
                             Foreground="{DynamicResource TextMuted}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Padding="{TemplateBinding Padding}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Send button -->
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center"
                            Click="OnAiFollowUpSend"
                            Visibility="{Binding AiLoading, Converter={StaticResource BoolToInverseVisibility}}"
                            ToolTip="Send (Enter)">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Width="28" Height="28"
                                        Background="{DynamicResource Depth3}"
                                        CornerRadius="14">
                                    <Path Width="13" Height="13" Stretch="Uniform"
                                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Data>
                                            <Binding Source="arrow-up" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Depth4}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Stop button (visible while streaming) -->
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center"
                            Click="OnAiStop"
                            Visibility="{Binding AiLoading, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Stop generating">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Width="32" Height="32"
                                        Background="{DynamicResource Depth3}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Path Width="10" Height="10" Stretch="Uniform"
                                          Fill="{DynamicResource TextMuted}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Data>
                                            <Binding Source="square" Converter="{x:Static conv:LucideIconConverter.Instance}"/>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Depth4}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>

        </Grid><!-- end AiPanel -->

        <!-- Empty state -->
        <TextBlock x:Name="EmptyState"
                   Text="Select a result to preview"
                   FontFamily="{DynamicResource UIFont}"
                   FontSize="{DynamicResource FontBase}"
                   Foreground="{DynamicResource TextMuted}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        </Grid><!-- end outer Grid -->
    </Border>
</UserControl>
