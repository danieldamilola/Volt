<UserControl x:Class="Volt.Views.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Volt.ViewModels"
             Width="300">

    <Border Background="{DynamicResource PreviewBg}"
            BorderBrush="{DynamicResource BorderStrong}"
            BorderThickness="1,0,0,0"
            Padding="20">

        <!-- Grid wrapping all panels so Border only has one child -->
        <Grid>

        <!-- Calculator -->
        <Grid x:Name="CalcPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       x:Name="CalcExprText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontMono13}"
                       Foreground="{DynamicResource TextMuted}"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1"
                       x:Name="CalcResultText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXxl}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Green}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="2"
                       Text="↵ copy"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXs}"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Color -->
        <Grid x:Name="ColorPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    x:Name="ColorSwatch"
                    Width="80" Height="80"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="1"
                       x:Name="ColorHexText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontXl}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,8"/>

            <StackPanel Grid.Row="2">
                <TextBlock x:Name="ColorRgbText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="{DynamicResource FontSm}"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock x:Name="ColorHslText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="{DynamicResource FontSm}"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Timer -->
        <Grid x:Name="TimerPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       x:Name="TimerCountdown"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontDisplay}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Progress bar -->
            <Border Grid.Row="1"
                    Height="6"
                    CornerRadius="3"
                    Background="{DynamicResource SurfaceLow}"
                    Margin="0,16,0,0">
                <Border x:Name="TimerBar"
                        CornerRadius="3"
                        Background="{DynamicResource Accent}"
                        HorizontalAlignment="Left"/>
            </Border>

            <TextBlock Grid.Row="2"
                       x:Name="TimerStatus"
                       Text="Press ↵ to start"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontSm}"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

            <Button Grid.Row="3"
                    x:Name="CancelTimerBtn"
                    Content="Cancel"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0"
                    Visibility="Collapsed"
                    Click="OnCancelTimer"/>
        </Grid>

        <!-- IP Address -->
        <Grid x:Name="IpPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LOCAL"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontXs}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}"/>
            <TextBlock Grid.Row="1"
                       x:Name="IpLocalText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontIp}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,4,0,0"/>

            <TextBlock Grid.Row="3"
                       Text="PUBLIC"
                       FontFamily="{DynamicResource UIFont}"
                       FontSize="{DynamicResource FontXs}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}"/>
            <TextBlock Grid.Row="4"
                       x:Name="IpPublicText"
                       FontFamily="{DynamicResource MonoFont}"
                       FontSize="{DynamicResource FontIp}"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,4,0,0"/>
        </Grid>

        <!-- AI -->
        <Grid x:Name="AiPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="AI Study Assistant"
                           FontFamily="{DynamicResource UIFont}"
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimary}"/>
            </Grid>

            <!-- Chat messages -->
            <ScrollViewer Grid.Row="1"
                          x:Name="AiScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,0,8">
                <ItemsControl x:Name="ChatMessages">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <!-- Role label -->
                                <TextBlock FontFamily="{DynamicResource UIFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="user">
                                                    <Setter Property="Text" Value="You"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                    <Setter Property="Text" Value="AI"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Message content -->
                                <TextBlock Text="{Binding Content}"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input area -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="AiFollowUp"
                         Grid.Column="0"
                         FontFamily="{DynamicResource UIFont}"
                         FontSize="13"
                         Background="{DynamicResource SurfaceLow}"
                         BorderThickness="0"
                         Padding="10,8"
                         VerticalAlignment="Center"
                         Text="Type a message…"
                         Foreground="{DynamicResource TextMuted}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1"
                        Width="32" Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="8,0,0,0"
                        Click="OnAiFollowUpSend">
                    <Path Data="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"
                          Width="16" Height="16" Stretch="Uniform"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyState"
                   Text="Select a result to preview"
                   FontFamily="{DynamicResource UIFont}"
                   FontSize="{DynamicResource FontBase}"
                   Foreground="{DynamicResource TextMuted}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        </Grid><!-- end outer Grid -->
    </Border>
</UserControl>
