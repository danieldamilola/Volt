<Window x:Class="Arc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Arc.Views"
        Title="Arc"
        Width="{DynamicResource WindowWidth}"
        MinWidth="520"
        MaxWidth="1200"
        MinHeight="56"
        MaxHeight="700"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Opacity="0"
        Loaded="OnLoaded">

    <!-- Root layout -->
    <Border x:Name="RootBorder"
            Margin="24"
            CornerRadius="{DynamicResource RadiusWindow}"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0">

        <Border.RenderTransform>
            <ScaleTransform x:Name="WindowScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.RenderTransformOrigin>0.5,0.1</Border.RenderTransformOrigin>

        <!-- Mouse-tracking grid: card | floating buttons -->
        <Grid MouseEnter="OnMainGridMouseEnter"
              MouseLeave="OnMainGridMouseLeave"
              Background="#01000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

        <!-- Search card (glass pill) -->
        <Border x:Name="SearchCardBorder"
                Grid.Column="0"
                CornerRadius="{DynamicResource RadiusPill}"
                BorderBrush="{DynamicResource GlassBorder}"
                BorderThickness="1">
            <Border.Background>
                <MultiBinding Converter="{StaticResource OpacityConverter}">
                    <Binding Path="Config.WindowOpacity"/>
                    <Binding Path="Config.BackgroundColor"/>
                </MultiBinding>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="64"
                                  ShadowDepth="16"
                                  Direction="270"
                                  Opacity="0.35"
                                  Color="#000000"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Config.EnableBlur}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <views:SearchBar x:Name="SearchBarControl"
                                 Grid.Row="0"
                                 DataContext="{Binding}"/>

                <Grid Grid.Row="1"
                      x:Name="ContentArea"
                      Visibility="Collapsed"
                      MaxHeight="600">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource BorderBrush}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                            <ColumnDefinition x:Name="PreviewColumn" Width="0"/>
                        </Grid.ColumnDefinitions>
                        <views:ResultsList x:Name="ResultsListControl" Grid.Column="0" DataContext="{Binding}"/>
                        <views:BrowsePanel x:Name="BrowsePanelControl" Grid.Column="0" DataContext="{Binding}" Visibility="Collapsed"/>
                        <views:PreviewPanel x:Name="PreviewPanelControl" Grid.Column="1" DataContext="{Binding}"/>
                    </Grid>

                    <!-- Hub empty state — shown when no recent items -->
                    <TextBlock x:Name="EmptyStateText"
                               Grid.Row="1"
                               Text="{Binding EmptyStateMessage}"
                               FontFamily="{DynamicResource UIFont}"
                               FontSize="{DynamicResource FontSm}"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,24"
                               Visibility="Collapsed"/>

                    <!-- Settings footer link (below content) -->
                    <Border Grid.Row="2"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8"
                            Visibility="Collapsed"
                            x:Name="SettingsFooter">
                        <Button x:Name="BtnSettingsFooter"
                                Style="{StaticResource CategoryButtonStyle}"
                                Click="OnSettingsFooterClick"
                                Cursor="Hand"
                                ToolTip="Settings (Ctrl+,)">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                                      Width="12" Height="12" Stretch="Uniform"
                                      Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                                <TextBlock Text="Settings"
                                           FontFamily="{DynamicResource UIFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Floating category buttons — appear on hover, right of card -->
        <Border x:Name="CategoryPanelContainer"
                Grid.Column="1"
                Width="0"
                ClipToBounds="True"
                VerticalAlignment="Top"
                Height="56">
            <StackPanel Orientation="Horizontal"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">

                <!-- Files -->
                <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,8,0"
                        Background="{DynamicResource GlassBg}"
                        BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Button x:Name="BtnFiles" Tag="files" Click="OnCategoryClick" ToolTip="Files (Ctrl+1)"
                            Style="{StaticResource CategoryButtonStyle}">
                        <Path x:Name="IconFiles"
                              Data="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"
                              Width="18" Height="18" Stretch="Uniform"
                              Stroke="{DynamicResource AccentFiles}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" Fill="Transparent"/>
                    </Button>
                </Border>

                <!-- Clipboard -->
                <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,8,0"
                        Background="{DynamicResource GlassBg}"
                        BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Button x:Name="BtnClipboard" Tag="clipboard" Click="OnCategoryClick" ToolTip="Clipboard (Ctrl+2)"
                            Style="{StaticResource CategoryButtonStyle}">
                        <Path x:Name="IconClipboard"
                              Data="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"
                              Width="18" Height="18" Stretch="Uniform"
                              Stroke="{DynamicResource AccentClipboard}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" Fill="Transparent"/>
                    </Button>
                </Border>

                <!-- Actions -->
                <Border Width="44" Height="44" CornerRadius="22"
                        Background="{DynamicResource GlassBg}"
                        BorderBrush="{DynamicResource GlassBorder}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.15" Color="#000000"/>
                    </Border.Effect>
                    <Button x:Name="BtnActions" Tag="actions" Click="OnCategoryClick" ToolTip="Actions (Ctrl+3)"
                            Style="{StaticResource CategoryButtonStyle}">
                        <Path x:Name="IconActions"
                              Data="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
                              Width="18" Height="18" Stretch="Uniform"
                              Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"/>
                    </Button>
                </Border>
            </StackPanel>
        </Border>

        </Grid><!-- end mouse-tracking grid -->
    </Border>
</Window>
